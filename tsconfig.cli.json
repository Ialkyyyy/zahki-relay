{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist/cli",
    "rootDir": "cli"
  },
  "include": ["cli/**/*"],
  "exclude": ["node_modules", "dist"]
}
